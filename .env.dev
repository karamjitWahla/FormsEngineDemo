# App exposure
TOOLJET_HOST=http://localhost:8080
TOOLJET_PORT=8080

# Images
POSTGRES_IMAGE=postgres:15
REDIS_IMAGE=redis:7-alpine
TOOLJET_IMAGE=tooljet/tooljet:v3.20.178-lts

# Postgres container bootstrap
POSTGRES_DB=tooljet
POSTGRES_USER=tooljet
POSTGRES_PASSWORD=tooljet

# ToolJet DB
TOOLJET_DB_HOST=postgres
TOOLJET_DB_PORT=5432
TOOLJET_DB_USER=tooljet
TOOLJET_DB_PASS=tooljet
TOOLJET_DB_NAME=tooljet
DATABASE_URL=postgres://tooljet:tooljet@postgres:5432/tooljet?sslmode=disable

# PostgREST
PGRST_DB_URI=postgres://tooljet:tooljet@postgres:5432/tooljet
PGRST_JWT_SECRET=supersecretjwt-local

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Security
SECRET_KEY_BASE=local-secret-key
LOCKBOX_MASTER_KEY=replace-with-64-char-hex-key

# Enterprise
TOOLJET_EDITION=ee
TOOLJET_LICENSE_

# Runtime
NODE_ENV=production
SERVE_CLIENT=true
